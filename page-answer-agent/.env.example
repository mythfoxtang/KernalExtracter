# Copy this file to `.env.local` and fill in your real values.
# Do not commit `.env.local`.

# Model API
DASHSCOPE_API_KEY=your_dashscope_api_key
# Optional alias if you prefer using another variable name
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_MODEL=qwen2.5-vl-3b-instruct
QWEN_TEXT_MODEL=qwen-plus
QWEN_ASR_MODEL=qwen3-asr-flash
PAGE_TASK_AGENT_TIMEOUT_SECONDS=180

# Backend
PAGE_CAPTURE_HOST=0.0.0.0
PAGE_CAPTURE_PORT=8010
PAGE_CAPTURE_BACKEND_URL=http://127.0.0.1:8010/api/page-capture

# Mobile page
PAGE_MOBILE_TITLE=页面答题结果
# Set this to your LAN URL when opening the page on a phone
PAGE_MOBILE_PUBLIC_URL=http://127.0.0.1:8010

# Browser capture
BROWSER_CDP_ENDPOINT=http://127.0.0.1:9222
PAGE_CAPTURE_HOTKEY=CTRL+SHIFT+Y

# Speech capture
PAGE_SPEECH_CAPTURE_HOTKEY=CTRL+SHIFT+U
PAGE_AUDIO_SAMPLE_RATE=16000
PAGE_AUDIO_CHANNELS=1
PAGE_AUDIO_DTYPE=int16

# ntfy notifications
NTFY_ENABLED=1
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=your_ntfy_topic
NTFY_TOKEN=
NTFY_PRIORITY_INFO=2
NTFY_PRIORITY_SUCCESS=3
NTFY_PRIORITY_ERROR=4
NTFY_TAGS_INFO=hourglass_flowing_sand,robot_face
NTFY_TAGS_SUCCESS=white_check_mark,robot_face
NTFY_TAGS_ERROR=warning,robot_face
